# EC Issuer Configuration
#
# This file shows example environment variables that can be used
# to configure the application. Copy this to .env and modify as needed.

# Server Configuration
# SERVER_HOST: Host address to bind the server to
# SERVER_PORT: Port to listen on
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# PostgreSQL Configuration
# POSTGRES_CONNECTION_STRING: PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
POSTGRES_CONNECTION_STRING=postgresql://ecissuer:ecissuer@localhost:5432/ecissuer