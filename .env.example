# EC Issuer Configuration
#
# This file shows example environment variables that can be used
# to configure the application. Copy this to .env and modify as needed.

# Config for running e2e tests which needs to know where to find
# the issuer that is being tested. Typically pointing to the ec-issuer
# service ran with docker/podman compose
EC_ISSUER_URL=http://localhost:8000

# Server Configuration
# Host address to bind the server to
SERVER_HOST=0.0.0.0
# Port to listen on
SERVER_PORT=8000
# SSI Agent configuration
SSI_AGENT_URL=http://localhost:8001
AWARDS_SERVICE_URL=http://localhost:8003

# Credential configuration ID
CREDENTIAL_CONFIGURATION_ID=openbadge_credential

# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
POSTGRES_CONNECTION_STRING=postgresql://ecissuer:ecissuer@localhost:5432/ecissuer

# CORS Configuration
# Comma-separated list of allowed origins for CORS
# Example: http://localhost:8080,http://localhost:3000,https://app.example.com
ALLOWED_CORS_DOMAINS=http://localhost:8080

# Development and debug
# Enable /metrics when flask running in dev and debug mode
DEBUG_METRICS=true
