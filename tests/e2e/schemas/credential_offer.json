{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["credential_issuer", "credential_configuration_ids", "grants"],
  "additionalProperties": false,
  "properties": {
    "credential_issuer": { "type": "string" },
    "credential_configuration_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "grants": {
      "type": "object",
      "required": ["authorization_code"],
      "additionalProperties": false,
      "properties": {
        "authorization_code": {
          "type": "object",
          "required": ["issuer_state"],
          "additionalProperties": false,
          "properties": {
            "issuer_state": { "type": "string" }
          }
        }
      }
    }
  }
}
