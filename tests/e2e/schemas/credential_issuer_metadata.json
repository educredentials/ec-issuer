{
  "$ref": "#/$defs/CredentialIssuerMetadata",
  "$defs": {
    "CredentialIssuerMetadata": {
      "title": "CredentialIssuerMetadata",
      "type": "object",
      "properties": {
        "credential_issuer": {"type": "string"},
        "credential_endpoint": {"type": "string"},
        "credential_configurations_supported": {
          "type": "object",
          "additionalProperties": {"$ref": "#/$defs/CredentialConfiguration"}
        },
        "authorization_servers": {
          "anyOf": [
            {"type": "array", "items": {"type": "string"}},
            {"type": "null"}
          ],
          "default": null
        },
        "nonce_endpoint": {
          "anyOf": [{"type": "string"}, {"type": "null"}],
          "default": null
        },
        "deferred_credential_endpoint": {
          "anyOf": [{"type": "string"}, {"type": "null"}],
          "default": null
        },
        "notification_endpoint": {
          "anyOf": [{"type": "string"}, {"type": "null"}],
          "default": null
        },
        "credential_response_encryption": {
          "anyOf": [
            {"type": "object", "additionalProperties": {"$ref": "#/$defs/CredentialResponseEncryption"}},
            {"type": "null"}
          ],
          "default": null
        },
        "batch_credential_issuance": {
          "anyOf": [
            {"type": "object", "additionalProperties": {"$ref": "#/$defs/BatchCredentialIssuance"}},
            {"type": "null"}
          ],
          "default": null
        },
        "display": {
          "anyOf": [
            {"type": "array", "items": {"$ref": "#/$defs/Display"}},
            {"type": "null"}
          ],
          "default": null
        }
      },
      "required": ["credential_issuer", "credential_endpoint", "credential_configurations_supported"]
    },
    "CredentialConfiguration": {
      "title": "CredentialConfiguration",
      "type": "object",
      "properties": {
        "format": {"type": "string"},
        "scope": {
          "anyOf": [{"type": "string"}, {"type": "null"}],
          "default": null
        },
        "cryptographic_binding_methods_supported": {
          "anyOf": [
            {"type": "array", "items": {"type": "string"}},
            {"type": "null"}
          ],
          "default": null
        },
        "credential_signing_alg_values_supported": {
          "anyOf": [
            {"type": "array", "items": {"type": "string"}},
            {"type": "null"}
          ],
          "default": null
        },
        "proof_types_supported": {
          "anyOf": [
            {"type": "object", "additionalProperties": {"$ref": "#/$defs/ProofType"}},
            {"type": "null"}
          ],
          "default": null
        },
        "display": {
          "anyOf": [
            {"type": "array", "items": {"$ref": "#/$defs/Display"}},
            {"type": "null"}
          ],
          "default": null
        }
      },
      "required": ["format"]
    },
    "ProofType": {
      "title": "ProofType",
      "type": "object",
      "properties": {
        "proof_signing_alg_values_supported": {"type": "array", "items": {"type": "string"}},
        "key_attestations_required": {
          "anyOf": [
            {"type": "object", "additionalProperties": {"$ref": "#/$defs/KeyAttestation"}},
            {"type": "null"}
          ],
          "default": null
        }
      },
      "required": ["proof_signing_alg_values_supported"]
    },
    "KeyAttestation": {
      "title": "KeyAttestation",
      "type": "object",
      "properties": {
        "key_storage": {
          "anyOf": [
            {"type": "array", "items": {"type": "string"}},
            {"type": "null"}
          ],
          "default": null
        },
        "user_authentication": {
          "anyOf": [
            {"type": "array", "items": {"type": "string"}},
            {"type": "null"}
          ],
          "default": null
        }
      },
      "required": []
    },
    "Display": {
      "title": "Display",
      "type": "object",
      "properties": {
        "name": {"type": "string"},
        "locale": {
          "anyOf": [{"type": "string"}, {"type": "null"}],
          "default": null
        },
        "logo": {
          "anyOf": [{"$ref": "#/$defs/Image"}, {"type": "null"}],
          "default": null
        },
        "description": {
          "anyOf": [{"type": "string"}, {"type": "null"}],
          "default": null
        },
        "background_color": {
          "anyOf": [{"type": "string"}, {"type": "null"}],
          "default": null
        },
        "background_image": {
          "anyOf": [{"$ref": "#/$defs/Image"}, {"type": "null"}],
          "default": null
        },
        "text_color": {
          "anyOf": [{"type": "string"}, {"type": "null"}],
          "default": null
        }
      },
      "required": ["name"]
    },
    "Image": {
      "title": "Image",
      "type": "object",
      "properties": {
        "uri": {"type": "string"},
        "alt_text": {
          "anyOf": [{"type": "string"}, {"type": "null"}],
          "default": null
        }
      },
      "required": ["uri"]
    },
    "CredentialResponseEncryption": {
      "title": "CredentialResponseEncryption",
      "type": "object",
      "properties": {
        "alg_values_supported": {"type": "array", "items": {"type": "string"}},
        "enc_values_supported": {"type": "array", "items": {"type": "string"}},
        "encryption_required": {"type": "boolean"}
      },
      "required": ["alg_values_supported", "enc_values_supported", "encryption_required"]
    },
    "BatchCredentialIssuance": {
      "title": "BatchCredentialIssuance",
      "type": "object",
      "properties": {
        "batch_size": {"type": "integer"}
      },
      "required": ["batch_size"]
    }
  }
}
