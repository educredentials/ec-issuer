{
  "credential_configuration_id": "OpenbadgeCredential",
  "format": "jwt_vc_json",
  "scope": "OpenbadgeCredential",
  "cryptographic_binding_methods_supported": [
    "jwk",
    "did:key"
  ],
  "credential_signing_alg_values_supported": [
    "ES256",
    "ES384",
    "RS256"
  ],
  "proof_types_supported": {
    "jwt": {
      "proof_signing_alg_values_supported": [
        "ES256",
        "ES384",
        "RS256"
      ],
      "key_attestations_required": {
        "key_storage": [
          "iso_18045_moderate"
        ],
        "user_authentication": [
          "iso_18045_moderate"
        ]
      }
    },
    "ldp_vp": {
      "proof_signing_alg_values_supported": [
        "Ed25519Signature2018",
        "Ed25519Signature2020"
      ]
    }
  },
  "credential_definition": {
    "type": [
      "VerifiableCredential",
      "OpenBadgeCredential"
    ]
  },
  "claims": [
    {
      "path": ["credentialSubject", "name"],
      "display": [
        {
          "name": "Name",
          "locale": "en"
        },
        {
          "name": "Naam",
          "locale": "nl"
        }
      ]
    },
    {
      "path": ["credentialSubject", "description"],
      "display": [
        {
          "name": "Description",
          "locale": "en"
        },
        {
          "name": "Beschrijving",
          "locale": "nl"
        }
      ]
    },
    {
      "path": ["credentialSubject", "criteria", "narrative"],
      "mandatory": true
    },
    {
      "path": ["issuer"],
      "mandatory": true
    },
    {
      "path": ["issuanceDate"],
      "mandatory": true
    }
  ],
  "display": [
    {
      "name": "Open Badge Credential",
      "locale": "en",
      "logo": {
        "uri": "https://example.com/images/logo.png",
        "alt_text": "Blue Logo"
      },
      "description": "A digital credential representing achievement or completion of a learning experience.",
      "background_color": "#12107c",
      "text_color": "#FFFFFF"
    },
    {
      "name": "Open Badge Referentie",
      "locale": "nl",
      "logo": {
        "uri": "https://example.com/images/logo.png",
        "alt_text": "Blauw Logo"
      },
      "description": "Een digitale referentie die een prestatie of voltooide leerervaring vertegenwoordigt.",
      "background_color": "#12107c",
      "text_color": "#FFFFFF"
    }
  ]
}
